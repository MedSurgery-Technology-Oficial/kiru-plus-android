    <!-- Descargo médico (5 secciones, texto exacto del iOS) -->
    <string name="disclaimer_title">DESCARGO DE RESPONSABILIDAD MÉDICA</string>
    <string name="disclaimer_section_1_title">1. Propósito</string>
    <string name="disclaimer_section_1_body">Herramienta educativa para estudiantes, residentes y cirujanos certificados (CMCG). Basada en ATLS, AAST, Guías de Tokio y el Nuevo Tratado 2025.</string>
    <string name="disclaimer_section_2_title">2. Aviso crítico</string>
    <string name="disclaimer_section_2_body">KIRU+ NO constituye consejo médico, diagnóstico ni tratamiento PARA CUALQUIER PERSONA QUE NO CUENTE CON CÉDULA DE MÉDICO. NO DEBE SER USADA por el público en general.</string>
    <string name="disclaimer_section_3_title">3. Limitaciones</string>
    <string name="disclaimer_section_3_body">MedSurgery NO es responsable por mala praxis, violaciones de la \"lex artis\" o daño a pacientes.</string>
    <string name="disclaimer_section_4_title">4. Uso apropiado</string>
    <string name="disclaimer_section_4_body">Estudio, preparación de residencia, simulación de casos. NO para uso clínico directo.</string>
    <string name="disclaimer_section_5_title">5. Confirmaciones</string>
    <string name="disclaimer_section_5_body">Confirmo que soy profesional o estudiante de la salud; entiendo que esto es educativo; no lo usaré como sustituto del juicio clínico; no compartiré contenido con el público general; acepto la política de privacidad y los términos de uso.</string>
    <string name="disclaimer_accept_checkbox">He leído y acepto el descargo médico</string>
    <string name="disclaimer_continue">Continuar</string>
    <string name="disclaimer_short_banner">Uso educativo. No es consejo médico.</string>

