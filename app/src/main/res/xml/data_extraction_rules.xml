<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Sin backup automático: datos sensibles médicos/sesión no deben copiarse a la nube de Google -->
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
    </device-transfer>
</data-extraction-rules>
