    <!-- Medical Disclaimer (5 sections - matches iOS exact copy) -->
    <string name="disclaimer_title">MEDICAL DISCLAIMER</string>
    <string name="disclaimer_section_1_title">1. Purpose</string>
    <string name="disclaimer_section_1_body">Educational tool for medical students, residents, and certified surgeons (CMCG certification). Based on ATLS, AAST, Tokyo Guidelines, and the New Treatise 2025.</string>
    <string name="disclaimer_section_2_title">2. Critical notice</string>
    <string name="disclaimer_section_2_body">KIRU+ DOES NOT constitute medical advice, diagnosis, or treatment FOR ANY PERSON WITHOUT A MEDICAL LICENSE. IT MUST NOT BE USED by the general public.</string>
    <string name="disclaimer_section_3_title">3. Limitations</string>
    <string name="disclaimer_section_3_body">MedSurgery is not responsible for malpractice, breaches of \"lex artis\", or harm to patients.</string>
    <string name="disclaimer_section_4_title">4. Appropriate use</string>
    <string name="disclaimer_section_4_body">Study, residency preparation, case simulation. NOT for direct clinical use.</string>
    <string name="disclaimer_section_5_title">5. Confirmations</string>
    <string name="disclaimer_section_5_body">I confirm I am a healthcare professional or student; I understand this is educational; I will not use it as a substitute for clinical judgment; I will not share content with the general public; I accept the privacy policy and terms of use.</string>
    <string name="disclaimer_accept_checkbox">I have read and accept the medical disclaimer</string>
    <string name="disclaimer_continue">Continue</string>
    <string name="disclaimer_short_banner">Educational use only. Not medical advice.</string>

